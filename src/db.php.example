<?php
/**
 * Database connection factory.
 *
 * Copy this file to src/db.php and fill in your MariaDB credentials.
 * src/db.php is gitignored — never commit real credentials.
 */
function getDB(): PDO
{
    static $pdo = null;
    if ($pdo === null) {
        $pdo = new PDO(
            'mysql:host=localhost;dbname=YOUR_DATABASE;charset=utf8mb4',
            'YOUR_USERNAME',
            'YOUR_PASSWORD',
            [PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION]
        );
    }
    return $pdo;
}
